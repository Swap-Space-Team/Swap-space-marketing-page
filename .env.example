# Environment variables reference. Copy to .env.local (gitignored) and fill in.
# This file documents the messaging (Bird SMS) additions; the app also reads
# existing vars such as SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY,
# RESEND_API_KEY, SLACK_WEBHOOK_URL, META_PIXEL_ID, META_ACCESS_TOKEN, BACKEND_URL.

# ── Infobip SMS ──────────────────────────────────────────────────────────────
# API key from the Infobip portal (Developers → API Keys). Sent as `App <key>`.
# Server-side only — never expose.
INFOBIP_API_KEY=

# Your account's personalized base host, shown on the Infobip dashboard/API docs,
# e.g. xxxxx.api.infobip.com (with or without https://).
INFOBIP_BASE_URL=

# Default SMS sender: a registered alphanumeric sender ID (<=11 chars) or number.
# Optional — omit to use the account default. Must be registered with Infobip.
INFOBIP_SENDER=
