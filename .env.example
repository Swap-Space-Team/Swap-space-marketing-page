# Environment variables reference. Copy to .env.local (gitignored) and fill in.
# This file documents the messaging (Bird SMS) additions; the app also reads
# existing vars such as SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY,
# RESEND_API_KEY, SLACK_WEBHOOK_URL, META_PIXEL_ID, META_ACCESS_TOKEN, BACKEND_URL.

# ── Bird (MessageBird) SMS ───────────────────────────────────────────────────
# Real Bird API key. Must be in `bk_{region}_{token}` form (e.g. bk_eu1_xxx);
# the SDK derives the API region from it. Server-side only — never expose.
BIRD_API_KEY=

# Default SMS sender: an E.164 number (+15551234567), a registered alphanumeric
# sender ID (<=11 chars), or a short code. Optional — if unset, Bird picks an
# eligible sender for the destination. Must be provisioned in your Bird workspace.
BIRD_SMS_FROM=

# Secret used to verify inbound Bird webhook signatures (delivery status + STOP).
# Set this to the signing key from your Bird webhook subscription (Phase 1).
BIRD_WEBHOOK_SECRET=
